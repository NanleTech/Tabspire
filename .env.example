# Tabspire Environment Variables

# Bible API (API.Bible)
REACT_APP_BIBLE_API_KEY=your_bible_api_key_here

# Unsplash API
REACT_APP_UNSPLASH_ACCESS_KEY=your_unsplash_access_key_here

# Pexels API (fallback for images)
REACT_APP_PEXELS_ACCESS_KEY=your_pexels_access_key_here

# Backend API Proxy URL (Vercel deployment URL)
# Set this to your deployed Vercel URL for production
# Leave empty for local development (will use relative paths)
REACT_APP_API_BASE_URL=

# Note: ELEVENLABS_API_KEY is now stored server-side in Vercel environment variables
# Do NOT add it to this file - it will be exposed in the client bundle
# Set it in Vercel dashboard: Project Settings > Environment Variables
